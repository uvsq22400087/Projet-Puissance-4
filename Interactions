import tkinter as tk

#cette fonction termine la partie celon les regles du jeu
def partie_terminee():
    if gagnant() or grille_pleine():
        return True
    else:
        return False

# le jeton est placer dans la grille par le clic sur la colonne
def clic_souris(event):
    global couleurJoueur
    global grille

    # Vérifie si la partie est terminée
    if partie_terminee():
        return

    # Récupère la colonne cliquée
    x = event.x
    colonne = 0
    ray = rayon()
    for col in range(NB_COLONNES):
        if x > col*ESPACEMENT + 2*(col)*ray and x < col*ESPACEMENT + 2*(col+1)*ray:
            colonne = col + 1
            break
